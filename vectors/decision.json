{
  "format": "email-guard-vectors/1",
  "spec_version": "1.0.0-rc.1",
  "category": "decision",
  "vectors": [
    {
      "id": "dec-001",
      "description": "A verdict listed in both block_on and review_on denies; deny beats review",
      "input": {
        "email": "x@mailinator.com",
        "config": { "block_on": ["invalid", "disposable"], "review_on": ["disposable"] }
      },
      "expected": { "verdict": "disposable", "action": "deny", "reasons": ["disposable_provider"], "degraded": false, "api_called": false }
    },
    {
      "id": "dec-002",
      "description": "Strict local-only setup: blocking unknown denies clean addresses that cannot be proven (no key, not degraded)",
      "input": {
        "email": "jane@acme-corp.com",
        "config": { "block_on": ["invalid", "disposable", "unknown"] }
      },
      "expected": { "verdict": "unknown", "action": "deny", "reasons": [], "degraded": false, "api_called": false }
    },
    {
      "id": "dec-003",
      "description": "Check order: syntax runs before reserved-TLD, first verdict wins",
      "input": { "email": ".jane@deleted.invalid" },
      "expected": { "verdict": "invalid", "action": "deny", "reasons": ["bad_syntax"], "degraded": false, "api_called": false }
    },
    {
      "id": "dec-004",
      "description": "Local short-circuit never burns an API call, even with a key configured",
      "input": {
        "email": "x@mailinator.com",
        "config": { "api_key": "test-key" },
        "api": { "result": "valid", "reason": "mailbox_accepts" }
      },
      "expected": { "verdict": "disposable", "action": "deny", "reasons": ["disposable_provider"], "degraded": false, "api_called": false }
    },
    {
      "id": "dec-005",
      "description": "Reserved TLD short-circuits before the transport as well",
      "input": {
        "email": "deleted+user274@deleted.invalid",
        "config": { "api_key": "test-key" },
        "api": { "result": "valid", "reason": "mailbox_accepts" }
      },
      "expected": { "verdict": "invalid", "action": "deny", "reasons": ["reserved_tld"], "degraded": false, "api_called": false }
    },
    {
      "id": "dec-006",
      "description": "Empty block_on allows everything, including provable junk; the verdict still reports it",
      "input": {
        "email": "x@deleted.invalid",
        "config": { "block_on": [] }
      },
      "expected": { "verdict": "invalid", "action": "allow", "reasons": ["reserved_tld"], "degraded": false, "api_called": false }
    }
  ]
}

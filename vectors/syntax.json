{
  "format": "email-guard-vectors/1",
  "spec_version": "1.0.0",
  "category": "syntax",
  "vectors": [
    {
      "id": "syntax-001",
      "description": "Plain address passes local checks; no key means verdict stays unknown",
      "input": { "email": "jane@acme-corp.com" },
      "expected": { "verdict": "unknown", "action": "allow", "reasons": [], "degraded": false, "api_called": false }
    },
    {
      "id": "syntax-002",
      "description": "Dots, plus-tag and subdomain are fine",
      "input": { "email": "jane.doe+tag@mail.acme-corp.com" },
      "expected": { "verdict": "unknown", "action": "allow", "reasons": [], "degraded": false, "api_called": false }
    },
    {
      "id": "syntax-003",
      "description": "Empty input",
      "input": { "email": "" },
      "expected": { "verdict": "invalid", "action": "deny", "reasons": ["bad_syntax"], "degraded": false, "api_called": false }
    },
    {
      "id": "syntax-004",
      "description": "No @ at all",
      "input": { "email": "janeacme-corp.com" },
      "expected": { "verdict": "invalid", "action": "deny", "reasons": ["bad_syntax"], "degraded": false, "api_called": false }
    },
    {
      "id": "syntax-005",
